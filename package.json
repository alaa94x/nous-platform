{
  "name": "nous-platform",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@nous/web",
    "dev:admin": "turbo dev --filter=@nous/admin",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean && find . -name 'node_modules' -type d -maxdepth 3 -exec rm -rf {} + 2>/dev/null; true"
  },
  "devDependencies": {
    "turbo": "^2.9.18"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@11.8.0"
}
