# ── Admin portal — copy to .env.local ───────────────────────
# Get from: https://app.supabase.com → your project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin access — set a strong secret for the admin email domain check
ADMIN_EMAIL_DOMAIN=nous.qa

# Telegram reminders — create the bot with @BotFather. Keep both values secret.
TELEGRAM_BOT_TOKEN=123456789:replace-with-your-bot-token
CRON_SECRET=replace-with-a-long-random-secret
